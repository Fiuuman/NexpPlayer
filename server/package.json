{
  "name": "music-server",
  "version": "2.0.0",
  "description": "Модульный бэкенд для музыкального приложения",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "init-db": "node -e \"import('./config/database.js').then(c => c.connectDatabase()).then(() => import('./models/initDatabase.js')).then(m => m.initDatabase())\""
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.6"
  },
  "engines": {
    "node": ">=20.11.0"
  }
}
